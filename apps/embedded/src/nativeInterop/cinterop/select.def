headers = sys/select.h
headerFilter = sys/select.h
package = select

---

#include <sys/select.h>

// Wrapper functions for FD_* macros (can't be called directly from Kotlin cinterop)

static inline void select_fd_zero(fd_set *set) {
    FD_ZERO(set);
}

static inline void select_fd_set(int fd, fd_set *set) {
    FD_SET(fd, set);
}

static inline int select_fd_isset(int fd, fd_set *set) {
    return FD_ISSET(fd, set);
}
